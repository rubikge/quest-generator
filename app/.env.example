# Google AI (Gemini) API key used by Genkit for narrative generation.
GEMINI_API_KEY=

# Firebase project configuration (App Hosting + Firestore). Filled per environment.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_APP_ID=

# When set, the Firebase SDK targets the local Firestore emulator for integration tests.
FIRESTORE_EMULATOR_HOST=localhost:8080
